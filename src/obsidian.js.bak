const GITHUB_TOKEN = process.env.GITHUB_TOKEN
const REPO = 'gabrielstrodiot-cmyk/Obsidian-vlaut'
const BRANCH = 'main'
const BASE_URL = 'https://api.github.com'

const headers = {
  'Authorization': `token ${GITHUB_TOKEN}`,
  'Accept': 'application/vnd.github.v3+json',
  'Content-Type': 'application/json'
}

// ── LISTE RÉCURSIVE DE TOUTES LES NOTES ──────────────────────
async function getAllNotesPaths() {
  const res = await fetch(
    `${BASE_URL}/repos/${REPO}/git/trees/HEAD?recursive=1`,
    { headers }
  )
  if (!res.ok) throw new Error('Impossible de lister le vault')
  const data = await res.json()
  return data.tree
    .filter(f => f.type === 'blob' && f.path.endsWith('.md'))
    .map(f => f.path)
}

// ── LECTURE PAR CHEMIN EXACT ──────────────────────────────────
async function readNoteByPath(path) {
  const res = await fetch(
    `${BASE_URL}/repos/${REPO}/contents/${encodeURIComponent(path)}?ref=${BRANCH}`,
    { headers }
  )
  if (!res.ok) throw new Error(`Note introuvable: ${path}`)
  const data = await res.json()
  return Buffer.from(data.content, 'base64').toString('utf-8')
}

// ── LECTURE PAR NOM PARTIEL ───────────────────────────────────
async function readNote(name) {
  const allPaths = await getAllNotesPaths()
  const query = name.toLowerCase().replace('.md', '')
  const match = allPaths.find(p => p.toLowerCase().includes(query))
  if (!match) throw new Error(`Note introuvable : ${name}`)
  return readNoteByPath(match)
}

// ── ÉCRITURE ──────────────────────────────────────────────────
async function writeNote(path, content, commitMessage = 'Jarvis: mise à jour note') {
  let sha
  try {
    const res = await fetch(
      `${BASE_URL}/repos/${REPO}/contents/${encodeURIComponent(path)}?ref=${BRANCH}`,
      { headers }
    )
    if (res.ok) { const data = await res.json(); sha = data.sha }
  } catch {}
  const body = {
    message: commitMessage,
    content: Buffer.from(content, 'utf-8').toString('base64'),
    branch: BRANCH,
    ...(sha && { sha })
  }
  const res = await fetch(
    `${BASE_URL}/repos/${REPO}/contents/${encodeURIComponent(path)}`,
    { method: 'PUT', headers, body: JSON.stringify(body) }
  )
  if (!res.ok) throw new Error(`Erreur écriture: ${await res.text()}`)
  return true
}

// ── LISTE UN DOSSIER (non récursif) ──────────────────────────
async function listFolder(path = '') {
  const res = await fetch(
    `${BASE_URL}/repos/${REPO}/contents/${encodeURIComponent(path)}?ref=${BRANCH}`,
    { headers }
  )
  if (!res.ok) throw new Error(`Dossier introuvable: ${path}`)
  const data = await res.json()
  return data.filter(f => f.type === 'file' && f.name.endsWith('.md')).map(f => f.path)
}

// ── RECHERCHE TEXTE ───────────────────────────────────────────
async function searchNotes(query) {
  const res = await fetch(
    `${BASE_URL}/search/code?q=${encodeURIComponent(query)}+repo:${REPO}+extension:md`,
    { headers }
  )
  if (!res.ok) return []
  const data = await res.json()
  return data.items?.map(i => i.path) || []
}

// ── NOTE ALÉATOIRE (pour le système prompt) ───────────────────
async function getRandomNote() {
  try {
    const files = await getAllNotesPaths()
    if (!files || files.length === 0) return null
    const path = files[Math.floor(Math.random() * files.length)]
    const content = await readNoteByPath(path)
    const name = path.split('/').pop().replace('.md', '')
    return { name, preview: content.slice(0, 400) }
  } catch (e) {
    console.error('getRandomNote:', e.message)
    return null
  }
}

// ── NOTES MODIFIÉES DANS LES 24H (via commits GitHub) ────────
async function getRecentlyModifiedNotes() {
  try {
    const since = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString()
    const res = await fetch(
      `${BASE_URL}/repos/${REPO}/commits?since=${since}&per_page=5`,
      { headers }
    )
    if (!res.ok) return []
    const commits = await res.json()
    if (!Array.isArray(commits) || commits.length === 0) return []

    const mdFiles = new Set()
    for (const commit of commits.slice(0, 3)) {
      try {
        const detail = await fetch(
          `${BASE_URL}/repos/${REPO}/commits/${commit.sha}`,
          { headers }
        )
        if (!detail.ok) continue
        const data = await detail.json()
        for (const file of (data.files || [])) {
          if (file.filename.endsWith('.md') && file.status !== 'removed') {
            mdFiles.add(file.filename)
          }
        }
      } catch {}
    }
    return [...mdFiles]
  } catch (e) {
    console.error('getRecentlyModifiedNotes:', e.message)
    return []
  }
}

// ── CHOISIT LA MEILLEURE NOTE POUR LE QUIZ ───────────────────
// Priorité : nouvelles notes non testées → notes peu testées → aléatoire
async function getNoteForQuiz(recentlyTestedPaths = []) {
  try {
    // 1. Notes modifiées dans les 24h et pas encore testées
    const recentNotes = await getRecentlyModifiedNotes()
    const freshUntested = recentNotes.filter(p => !recentlyTestedPaths.includes(p))
    if (freshUntested.length > 0) {
      const path = freshUntested[0]
      const content = await readNoteByPath(path)
      const name = path.split('/').pop().replace('.md', '')
      return { path, name, content, isNew: true }
    }

    // 2. Toutes les notes, en évitant les récemment testées
    const allFiles = await getAllNotesPaths()
    if (!allFiles || allFiles.length === 0) return null
    const untested = allFiles.filter(p => !recentlyTestedPaths.includes(p))
    const pool = untested.length > 0 ? untested : allFiles
    const path = pool[Math.floor(Math.random() * pool.length)]
    const content = await readNoteByPath(path)
    const name = path.split('/').pop().replace('.md', '')
    return { path, name, content, isNew: false }
  } catch (e) {
    console.error('getNoteForQuiz:', e.message)
    return null
  }
}

module.exports = {
  readNote, readNoteByPath, writeNote,
  getRandomNote, listFolder, searchNotes,
  getAllNotesPaths, getRecentlyModifiedNotes, getNoteForQuiz
}